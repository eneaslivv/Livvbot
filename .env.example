# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_PROJECT_REF=xxxxx

# OpenAI (para scripts de ingest desde LIVV — los tenants usan su propia key)
OPENAI_API_KEY=sk-...

# Encryption key para OpenAI keys de tenants
# Generar con: openssl rand -base64 32
TENANT_ENCRYPTION_KEY=base64_de_32_bytes
