# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_or_publishable_key>

# Where this dashboard is hosted. Used by magic-link / invite redirects.
# Dev:   http://localhost:3000
# Prod:  https://bots.your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — only needed for admin features that manipulate auth.users
# (invite member by email, list users). Leave empty if not needed.
SUPABASE_SERVICE_ROLE_KEY=

# Set to "1" to boot the dashboard with in-memory mock data (no Supabase needed).
# Useful for UI demos. Writes don't persist.
# NEXT_PUBLIC_PREVIEW_MODE=
